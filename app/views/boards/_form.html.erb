<%= form_with(model: board) do |form| %>
  <% if board.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(board.errors.count, "error") %> prohibited this board from being saved:</h2>

      <ul>
        <% board.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, style: "display: block" %>
    <%= form.text_field :name %>
  </div>

  <h3>Columns</h3>
  <div id='columns'>
    <%= f.fields_for :columns do |task| %>
      <%= render 'column_fields', :f => task %>
    <% end %>
    <div class='links'>
      <%= link_to_add_association 'add column', f, :columns %>
    </div>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
